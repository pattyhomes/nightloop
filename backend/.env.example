# Runtime environment
NODE_ENV=development

# HTTP port for backend server (local demo API on /api/recommendations)
PORT=4000

# Dev/test only: pin recommendation scoring to a fixed point in time.
# Omit (or leave unset) for normal runtime — real current time is used by default.
# NIGHTLOOP_FIXED_NOW=2026-03-09T04:00:00.000Z

# ── Foursquare Places API v3 ─────────────────────────────────────────────────
# Required for venue enrichment (npm run enrich:foursquare).
# Obtain at: https://foursquare.com/developers/app
# Scope needed: "Places" (read-only access to place search and place details).
# Not needed for the dev server or recommendation API — only the enrichment script.
# Never commit the real key; copy this file to .env.local and fill in the value.
# FOURSQUARE_API_KEY=your_api_key_here
